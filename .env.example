# AI Journal MVP 环境变量示例
# 复制此文件为 .env.local 并填入真实值

# GMI Cloud API Key（从 ai-router-worker 获取）
NEXT_PUBLIC_API_KEY=your_api_key_here

# 默认模型
NEXT_PUBLIC_DEFAULT_MODEL=anthropic/claude-opus-4.6

# API Base URL（可选，默认使用 ai-router-worker）
# NEXT_PUBLIC_API_BASE=https://ai-router-worker.zdjingji.workers.dev
